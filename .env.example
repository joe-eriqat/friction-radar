# Friction Radar configuration
#
# Provider, model, and endpoint are all config — direct OpenAI and any OpenAI-compatible
# gateway run the identical code path (see docs/specs/02-llm-connector.md).

# LiteLLM model string used for analysis. Default: openai/gpt-4o-mini
FRICTION_RADAR_MODEL=openai/gpt-4o-mini

# Sampling temperature. Default 0 (near-greedy) for stable, repeatable categorization.
# Set to "none" to omit it for models that reject an explicit temperature (e.g. reasoning models).
FRICTION_RADAR_TEMPERATURE=0

# Direct-OpenAI auth (used for openai/* models when no custom base URL is set).
# OPENAI_API_KEY=sk-...

# Optional: route through any OpenAI-compatible endpoint (e.g. the OpenClaw gateway).
# When set, requests go here instead of api.openai.com.
# FRICTION_RADAR_LLM_BASE_URL=http://localhost:19000/v1

# Where the SQLite database lives (relative paths resolved from the repo root).
FRICTION_RADAR_DB=friction_radar.db
